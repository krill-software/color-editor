{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Color Editor",
  "version": "0.4.0",
  "identifier": "software.krill.color-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Color Editor",
        "width": 1296,
        "height": 800,
        "minWidth": 720,
        "minHeight": 445,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#FAFAFF"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A minimal color scheme editor for Linux",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path to a .css file to open"
        }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3Nzg5QTc4MEExOTM4MjIKUldRaU9Ca0tlSnA0aDQzcXJLRWtKWTI0K0lDM3IwTW4wcGUzdFZ5RE01ckYraU5nL1FRZWRXRmgK",
      "endpoints": [
        "https://github.com/krill-software/color-editor/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Color theme editor",
    "longDescription": "Edit a set of named CSS color variables, see them rendered live, and save the result as a colors.css file of custom properties.",
    "fileAssociations": [
      {
        "ext": ["css"],
        "name": "CSS",
        "description": "CSS stylesheet",
        "mimeType": "text/css",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "section": "graphics",
        "priority": "optional",
        "desktopTemplate": "main.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
