{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Color Editor",
  "version": "0.1.0",
  "identifier": "software.krill.color-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Color Editor",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#FAFAFF"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A minimal color scheme editor for Linux",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "description": "Path to a .palette.json file to open"
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Color scheme editor",
    "longDescription": "Generate a balanced color palette from a single picked color using OKLCH. Save and load as JSON. Hex, RGB and CSS-variable output.",
    "fileAssociations": [
      {
        "ext": ["json"],
        "name": "Krill Palette",
        "description": "Krill colors palette",
        "mimeType": "application/x-krill-palette+json",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "section": "graphics",
        "priority": "optional",
        "desktopTemplate": "main.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
